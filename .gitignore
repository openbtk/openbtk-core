.ipynb_checkpoints/

# Secrets / credentials — NEVER commit these
*.env
.env.*
*.key
*.pem
secrets.yaml
credentials.json
.secrets.baseline

# ---------------------------------------------------------------------------
# Biomedical data files — NEVER commit real or even synthetic large data
# ---------------------------------------------------------------------------
data/
*.csv
*.tsv
*.parquet

# Clinical text / EHR
*.cda
*.hl7

# Imaging
*.dcm
*.dicom
*.nii
*.nii.gz
*.svs

# Biosignals
*.edf
*.bdf
*.hea
*.dat
*.wav

# Genomics
*.vcf
*.vcf.gz
*.bam
*.sam
*.bcf
*.fastq
*.fastq.gz
*.fasta
*.h5ad
*.loom

# Video
*.mp4
*.avi
*.mov

# Model artifacts / caches
*.pt
*.pth
*.bin
*.safetensors
.cache/
models/


# Exceptions — allow small fixture files explicitly added
!tests/fixtures/**/*.json
!tests/fixtures/**/sample_*.txt

# Ignore documentation, spec files, and local agent context
docs/
specs/
CLAUDE.md
claude.md
